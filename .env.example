# GrooveLink Environment Configuration
# Copy to .env and customize as needed.

# Example API base URL
GROOVELINK_BASE_URL=https://api.example.com

# Default timeout in seconds
GROOVELINK_TIMEOUT=30

# Rate limit (requests per minute)
GROOVELINK_RATE_LIMIT=100

# Circuit breaker threshold
GROOVELINK_CIRCUIT_THRESHOLD=5
